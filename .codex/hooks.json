{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "^apply_patch$",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"$(git rev-parse --show-toplevel)/.claude/hooks/format-on-edit.sh\"",
            "timeout": 30,
            "statusMessage": "Formatting edited files"
          }
        ]
      }
    ]
  }
}
